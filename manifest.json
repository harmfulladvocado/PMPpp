{
  "manifest_version": 3,
  "name": "Pelckmansportaal ++",
  "version": "1.0.0",
  "description": "Enhance your PelckmansPortaal experience.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pmppp@victor.bonte",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "alarms", "cookies"],
  "host_permissions": [
    "*://*.pelckmansportaal.be/*",
    "*://id.pelckmans.be/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.pelckmansportaal.be/*",
        "*://id.pelckmans.be/*"
      ],
      "js": ["content.js"],
      "css": ["inject.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["Themes/Midnight_sapphire.png"],
      "matches": [
        "*://*.pelckmansportaal.be/*",
        "*://id.pelckmans.be/*"
      ]
    }
  ]
}
